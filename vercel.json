{
  "version": 2,
  "buildCommand": "cd client && npm ci && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60,
      "memory": 1024
    }
  },
  "limits": {
    "duration": 60000
  },
  "rewrites": [
    {
      "source": "/secret-admin/(.*)",
      "destination": "/index.html"
    },
    {
      "source": "/secret-admin",
      "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
